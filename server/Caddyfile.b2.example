# B2: HTTP/3 (QUIC) static hosting — same pull + client-side RVC design as B1, multiplexed over QUIC.
# Parallel to the authors’ campus2_bounding_boxes-caddy_HTTP3 layout (protocols h1 h2 h3, TLS, /assets/...).
# There is no WebSocket RVC in this baseline; the viewer selects tiles locally (useLocalRVC: true).
#
# From server/ (requires trusted certs for QUIC, e.g. mkcert → server/certs/):
#   caddy run --config Caddyfile.b2.example
#
# Trust ./certs/web3d.local.pem or add SANs your browser accepts.

{
	auto_https disable_redirects
	admin off
	servers {
		protocols h1 h2 h3
	}
}

https://127.0.0.1:8543, https://localhost:8543, https://web3d.local:8543 {
	bind 0.0.0.0
	tls ./certs/web3d.local.pem ./certs/web3d.local-key.pem

	handle_path /assets/* {
		root * ../dataset/toy_example
		header Cache-Control "no-store"
		file_server
	}

	handle {
		root * ../dataset/toy_example
		try_files {path} /index.html
		file_server
		header Cache-Control "no-store"
	}

	header Access-Control-Allow-Origin *
	header Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
}
